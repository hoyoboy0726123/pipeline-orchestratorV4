# 複製此檔案為 .env 並填入你的 API Key
# cp .env.example .env

# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram（選填，也可透過 Web UI 設定）────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 其他 ──────────────────────────────────────────────────────
TIMEZONE=Asia/Taipei
OUTPUT_BASE_PATH=~/ai_output
PIPELINE_DIR=~/pipelines
